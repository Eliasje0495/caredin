// prisma/schema.prisma — Caredin.nl
// Zorg flexwerk + fulltime platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  password      String?
  name          String?
  image         String?
  phone         String?
  role          UserRole  @default(WORKER)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastLoginAt   DateTime?

  accounts      Account[]
  sessions      Session[]
  workerProfile WorkerProfile?
  employer      Employer?
  applications  ShiftApplication[]
  reviews       Review[]          @relation("ReviewedUser")
  givenReviews  Review[]          @relation("ReviewerUser")

  @@index([email])
  @@map("users")
}

enum UserRole {
  WORKER
  EMPLOYER
  ADMIN
}

// ─────────────────────────────────────────────
// WORKER PROFILE
// ─────────────────────────────────────────────
model WorkerProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  bio              String?   @db.Text
  dateOfBirth      DateTime?
  address          String?
  city             String?
  postalCode       String?
  primaryFunction  ZorgFunction?

  contractType  ContractType @default(ZZP)

  // BIG verificatie
  bigNumber     String?
  bigStatus     VerifyStatus @default(UNVERIFIED)
  bigVerifiedAt DateTime?

  // SKJ verificatie
  skjNumber     String?
  skjStatus     VerifyStatus @default(UNVERIFIED)
  skjVerifiedAt DateTime?

  // KABIZ verificatie
  kabizNumber     String?
  kabizStatus     VerifyStatus @default(UNVERIFIED)
  kabizVerifiedAt DateTime?

  // DUO Diplomaregister
  diplomaNumber     String?
  diplomaStatus     VerifyStatus @default(UNVERIFIED)
  diplomaVerifiedAt DateTime?

  // AGB-code (Vektis)
  agbCode         String?
  agbStatus       VerifyStatus @default(UNVERIFIED)
  agbVerifiedAt   DateTime?

  // CRKBO
  crkboNumber   String?

  // NVPA / NIP
  nvpaNipNumber String?

  // KvK verificatie (ZZP)
  kvkNumber         String?
  kvkStatus         VerifyStatus @default(UNVERIFIED)
  kvkVerifiedAt     DateTime?
  kvkCompanyName    String?

  sectors       WorkerSector[]
  functions     WorkerFunction[]

  hourlyRate    Decimal   @default(0) @db.Decimal(8,2)
  availability  Json?
  radius        Int       @default(30)

  stripeAccountId String?

  isActive      Boolean   @default(true)
  isVerified    Boolean   @default(false)

  totalShifts   Int       @default(0)
  totalHours    Decimal   @default(0) @db.Decimal(10,2)
  totalEarned   Decimal   @default(0) @db.Decimal(10,2)
  averageRating Decimal?  @db.Decimal(3,2)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("worker_profiles")
}

enum ContractType {
  ZZP
  LOONDIENST
}

enum VerifyStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

model WorkerSector {
  id       String        @id @default(cuid())
  workerId String
  worker   WorkerProfile @relation(fields: [workerId], references: [id], onDelete: Cascade)
  sector   Sector

  @@unique([workerId, sector])
  @@map("worker_sectors")
}

model WorkerFunction {
  id       String        @id @default(cuid())
  workerId String
  worker   WorkerProfile @relation(fields: [workerId], references: [id], onDelete: Cascade)
  function ZorgFunction

  @@unique([workerId, function])
  @@map("worker_functions")
}

enum Sector {
  VVT
  GGZ
  JEUGDZORG
  ZIEKENHUIS
  HUISARTSENZORG
  GEHANDICAPTENZORG
  KRAAMZORG
  THUISZORG
  REVALIDATIE
  OVERIG
}

enum ZorgFunction {
  VERPLEEGKUNDIGE
  VERZORGENDE_IG
  HELPENDE_PLUS
  HELPENDE
  ZORGASSISTENT
  GGZ_AGOOG
  PERSOONLIJK_BEGELEIDER
  GEDRAGSDESKUNDIGE
  ARTS
  SPECIALIST_OUDERENGENEESKUNDE
  FYSIOTHERAPEUT
  ERGOTHERAPEUT
  LOGOPEDIST
  KRAAMVERZORGENDE
  OVERIG
}

// ─────────────────────────────────────────────
// EMPLOYER
// ─────────────────────────────────────────────
model Employer {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  companyName   String
  kvkNumber     String       @unique
  kvkStatus     VerifyStatus @default(UNVERIFIED)
  kvkVerifiedAt DateTime?

  sector        Sector?
  address       String?
  city          String?
  postalCode    String?
  website       String?
  description   String?  @db.Text
  logo          String?

  planType         PlanType @default(PAY_PER_HOUR)
  stripeCustomerId String?

  totalShiftsPosted Int     @default(0)
  totalHoursFilled  Decimal @default(0) @db.Decimal(10,2)

  isVerified    Boolean  @default(false)
  isActive      Boolean  @default(true)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  shifts        Shift[]
  vacancies     Vacancy[]

  @@map("employers")
}

enum PlanType {
  PAY_PER_HOUR
  SUBSCRIPTION
  COMMISSION
}

// ─────────────────────────────────────────────
// SHIFT (flexdienst)
// ─────────────────────────────────────────────
model Shift {
  id         String   @id @default(cuid())
  employerId String
  employer   Employer @relation(fields: [employerId], references: [id])

  title       String
  description String?  @db.Text
  sector      Sector
  function    ZorgFunction
  address     String
  city        String
  postalCode  String
  lat         Decimal? @db.Decimal(10,7)
  lng         Decimal? @db.Decimal(10,7)

  startTime   DateTime
  endTime     DateTime
  breakMinutes Int     @default(30)

  hourlyRate  Decimal  @db.Decimal(8,2)

  // Nachttoeslag — automatisch +2.5% vanaf 00:00
  isNightShift    Boolean @default(false)
  nightSurcharge  Decimal @default(0) @db.Decimal(5,4)  // 0.025 = 2.5%

  isUrgent    Boolean  @default(false)

  requiresBig  Boolean @default(false)
  requiresSkj  Boolean @default(false)
  requiresKvk  Boolean @default(false)
  minExperience Int    @default(0)

  status      ShiftStatus @default(OPEN)
  filledAt    DateTime?
  cancelledAt DateTime?
  cancelReason String?

  platformFeePerHour Decimal @default(3.00) @db.Decimal(8,2)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  applications ShiftApplication[]

  @@index([sector])
  @@index([status])
  @@index([startTime])
  @@index([city])
  @@map("shifts")
}

enum ShiftStatus {
  OPEN
  FILLED
  IN_PROGRESS
  COMPLETED
  APPROVED
  CANCELLED
}

// ─────────────────────────────────────────────
// SHIFT APPLICATION
// ─────────────────────────────────────────────
model ShiftApplication {
  id      String @id @default(cuid())
  shiftId String
  shift   Shift  @relation(fields: [shiftId], references: [id])
  userId  String
  user    User   @relation(fields: [userId], references: [id])

  status  ApplicationStatus @default(PENDING)

  checkedInAt  DateTime?
  checkedOutAt DateTime?

  hoursWorked  Decimal? @db.Decimal(8,2)
  payoutAmount Decimal? @db.Decimal(10,2)
  platformFee  Decimal? @db.Decimal(10,2)
  paidAt       DateTime?

  stripeTransferId String?

  appliedAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([shiftId, userId])
  @@map("shift_applications")
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
  COMPLETED
  APPROVED
}

// ─────────────────────────────────────────────
// VACANCY (fulltime)
// ─────────────────────────────────────────────
model Vacancy {
  id         String   @id @default(cuid())
  employerId String
  employer   Employer @relation(fields: [employerId], references: [id])

  title       String
  description String  @db.Text
  sector      Sector
  function    ZorgFunction
  city        String
  address     String?

  contractType  ContractType @default(LOONDIENST)
  hoursPerWeek  Int?
  salaryMin     Decimal? @db.Decimal(10,2)
  salaryMax     Decimal? @db.Decimal(10,2)

  requiresBig   Boolean @default(false)
  requiresSkj   Boolean @default(false)
  minExperience Int     @default(0)

  status        VacancyStatus @default(OPEN)

  placementFee    Decimal? @db.Decimal(10,2)
  placementFeePct Decimal? @db.Decimal(5,2)

  publishedAt DateTime  @default(now())
  expiresAt   DateTime?
  filledAt    DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([sector])
  @@index([status])
  @@map("vacancies")
}

enum VacancyStatus {
  DRAFT
  OPEN
  FILLED
  EXPIRED
  CANCELLED
}

// ─────────────────────────────────────────────
// REVIEWS
// ─────────────────────────────────────────────
model Review {
  id         String @id @default(cuid())
  reviewerId String
  reviewer   User   @relation("ReviewerUser", fields: [reviewerId], references: [id])
  reviewedId String
  reviewed   User   @relation("ReviewedUser", fields: [reviewedId], references: [id])

  rating     Int
  comment    String? @db.Text

  createdAt  DateTime @default(now())

  @@unique([reviewerId, reviewedId])
  @@map("reviews")
}

// ─────────────────────────────────────────────
// NEXTAUTH
// ─────────────────────────────────────────────
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Setting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt

  @@map("settings")
}

// ─────────────────────────────────────────────
// CHAT
// ─────────────────────────────────────────────
model ChatConversation {
  id           String        @id @default(cuid())
  visitorName  String?
  visitorEmail String?
  status       String        @default("open")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  messages     ChatMessage[]

  @@index([status])
  @@map("chat_conversations")
}

model ChatMessage {
  id             String           @id @default(cuid())
  conversationId String
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         String           // "visitor" | "admin"
  content        String           @db.Text
  createdAt      DateTime         @default(now())

  @@index([conversationId])
  @@map("chat_messages")
}
