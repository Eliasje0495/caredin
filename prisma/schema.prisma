// prisma/schema.prisma — Caredin.nl
// Zorg flexwerk + fulltime platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  password      String?
  name          String?
  image         String?
  phone         String?
  role          UserRole  @default(WORKER)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastLoginAt   DateTime?

  accounts      Account[]
  sessions      Session[]
  workerProfile WorkerProfile?
  employer      Employer?
  applications  ShiftApplication[]
  reviews       Review[]          @relation("ReviewedUser")
  givenReviews  Review[]          @relation("ReviewerUser")
  pushSubscriptions PushSubscription[]
  declaraties       Declaratie[]
  notifications     Notification[]
  referralCode    String?   @unique  // bijv. "ANNA-X7K2"
  referredById    String?
  referredBy      User?     @relation("UserReferrals", fields: [referredById], references: [id])
  referrals       User[]    @relation("UserReferrals")
  referralRewards ReferralReward[]

  @@index([email])
  @@map("users")
}

enum UserRole {
  WORKER
  EMPLOYER
  ADMIN
}

// ─────────────────────────────────────────────
// WORKER PROFILE
// ─────────────────────────────────────────────
model WorkerProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  bio              String?   @db.Text
  dateOfBirth      DateTime?
  address          String?
  city             String?
  postalCode       String?
  primaryFunction  ZorgFunction?

  contractType  ContractType @default(ZZP)

  // BIG verificatie
  bigNumber     String?
  bigStatus     VerifyStatus @default(UNVERIFIED)
  bigVerifiedAt DateTime?

  // SKJ verificatie
  skjNumber     String?
  skjStatus     VerifyStatus @default(UNVERIFIED)
  skjVerifiedAt DateTime?
  skjExpiresAt  DateTime?    // Verloopdatum vanuit SKJ-register

  // KABIZ verificatie
  kabizNumber     String?
  kabizStatus     VerifyStatus @default(UNVERIFIED)
  kabizVerifiedAt DateTime?

  // DUO Diplomaregister
  diplomaNumber     String?
  diplomaStatus     VerifyStatus @default(UNVERIFIED)
  diplomaVerifiedAt DateTime?

  // AGB-code (Vektis)
  agbCode         String?
  agbStatus       VerifyStatus @default(UNVERIFIED)
  agbVerifiedAt   DateTime?

  // CRKBO
  crkboNumber   String?

  // NVPA / NIP
  nvpaNipNumber String?

  // KvK verificatie (ZZP)
  kvkNumber         String?
  kvkStatus         VerifyStatus @default(UNVERIFIED)
  kvkVerifiedAt     DateTime?
  kvkCompanyName    String?

  // VOG (Verklaring Omtrent Gedrag)
  vogUrl           String?
  vogStatus        VerifyStatus @default(UNVERIFIED)
  vogVerifiedAt    DateTime?
  vogExpiresAt     DateTime?    // VOG verloopt na 3 jaar
  vogRejectedAt    DateTime?
  vogRejectedReason String?

  sectors       WorkerSector[]
  functions     WorkerFunction[]

  hourlyRate    Decimal   @default(0) @db.Decimal(8,2)
  availability  Json?
  radius        Int       @default(30)

  stripeAccountId String?

  isActive      Boolean   @default(true)
  isVerified    Boolean   @default(false)

  totalShifts   Int       @default(0)
  totalHours    Decimal   @default(0) @db.Decimal(10,2)
  totalEarned   Decimal   @default(0) @db.Decimal(10,2)
  averageRating Decimal?  @db.Decimal(3,2)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("worker_profiles")
}

enum ContractType {
  ZZP
  LOONDIENST
}

enum VerifyStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

model WorkerSector {
  id       String        @id @default(cuid())
  workerId String
  worker   WorkerProfile @relation(fields: [workerId], references: [id], onDelete: Cascade)
  sector   Sector

  @@unique([workerId, sector])
  @@map("worker_sectors")
}

model WorkerFunction {
  id       String        @id @default(cuid())
  workerId String
  worker   WorkerProfile @relation(fields: [workerId], references: [id], onDelete: Cascade)
  function ZorgFunction

  @@unique([workerId, function])
  @@map("worker_functions")
}

enum Sector {
  VVT
  GGZ
  JEUGDZORG
  ZIEKENHUIS
  HUISARTSENZORG
  GEHANDICAPTENZORG
  KRAAMZORG
  THUISZORG
  REVALIDATIE
  OVERIG
}

enum ZorgFunction {
  VERPLEEGKUNDIGE
  VERZORGENDE_IG
  HELPENDE_PLUS
  HELPENDE
  ZORGASSISTENT
  GGZ_AGOOG
  PERSOONLIJK_BEGELEIDER
  GEDRAGSDESKUNDIGE
  ARTS
  SPECIALIST_OUDERENGENEESKUNDE
  FYSIOTHERAPEUT
  ERGOTHERAPEUT
  LOGOPEDIST
  KRAAMVERZORGENDE
  OVERIG
}

// ─────────────────────────────────────────────
// EMPLOYER
// ─────────────────────────────────────────────
model Employer {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  companyName   String
  kvkNumber     String       @unique
  kvkStatus     VerifyStatus @default(UNVERIFIED)
  kvkVerifiedAt DateTime?

  sector        Sector?
  address       String?
  city          String?
  postalCode    String?
  website       String?
  description   String?  @db.Text
  logo          String?

  planType         PlanType @default(PAY_PER_HOUR)
  stripeCustomerId String?

  totalShiftsPosted Int     @default(0)
  totalHoursFilled  Decimal @default(0) @db.Decimal(10,2)

  isVerified    Boolean  @default(false)
  isActive      Boolean  @default(true)

  notificationSettings Json?  // { new_application, checkout_pending, auto_approved, shift_reminder, no_applicants, platform_updates }

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  shifts          Shift[]
  vacancies       Vacancy[]
  apiKeys         ApiKey[]
  webhooks        WebhookEndpoint[]
  locations       Location[]
  blockedWorkers  BlockedWorker[]
  declaraties     Declaratie[]
  shiftTemplates  ShiftTemplate[]

  @@map("employers")
}

enum PlanType {
  PAY_PER_HOUR
  SUBSCRIPTION
  COMMISSION
}

// ─────────────────────────────────────────────
// SHIFT (flexdienst)
// ─────────────────────────────────────────────
model Shift {
  id         String   @id @default(cuid())
  employerId String
  employer   Employer @relation(fields: [employerId], references: [id])

  title       String
  description String?  @db.Text
  sector      Sector
  function    ZorgFunction
  address     String
  city        String
  postalCode  String
  lat         Decimal? @db.Decimal(10,7)
  lng         Decimal? @db.Decimal(10,7)

  startTime   DateTime
  endTime     DateTime
  breakMinutes Int     @default(30)

  hourlyRate  Decimal  @db.Decimal(8,2)

  // Nachttoeslag — automatisch +2.5% vanaf 00:00
  isNightShift    Boolean @default(false)
  nightSurcharge  Decimal @default(0) @db.Decimal(5,4)  // 0.025 = 2.5%

  isUrgent    Boolean  @default(false)

  requiresBig  Boolean @default(false)
  requiresSkj  Boolean @default(false)
  requiresKvk  Boolean @default(true)
  minExperience Int    @default(0)

  status      ShiftStatus @default(OPEN)
  filledAt    DateTime?
  cancelledAt DateTime?
  cancelReason String?

  locationId   String?
  location     Location? @relation(fields: [locationId], references: [id])

  isRecurring     Boolean @default(false)
  recurrenceRule  String?      // JSON: {"freq":"weekly","days":[1,5],"until":"2026-12-31","count":null}
  parentShiftId   String?      // verwijst naar de originele template-shift

  platformFeePerHour Decimal @default(3.00) @db.Decimal(8,2)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  applications ShiftApplication[]

  @@index([sector])
  @@index([status])
  @@index([startTime])
  @@index([city])
  @@map("shifts")
}

enum ShiftStatus {
  OPEN
  FILLED
  IN_PROGRESS
  COMPLETED
  APPROVED
  CANCELLED
}

// ─────────────────────────────────────────────
// SHIFT APPLICATION
// ─────────────────────────────────────────────
model ShiftApplication {
  id      String @id @default(cuid())
  shiftId String
  shift   Shift  @relation(fields: [shiftId], references: [id])
  userId  String
  user    User   @relation(fields: [userId], references: [id])

  status  ApplicationStatus @default(PENDING)

  checkedInAt  DateTime?
  checkedOutAt DateTime?

  hoursWorked  Decimal? @db.Decimal(8,2)
  payoutAmount Decimal? @db.Decimal(10,2)
  platformFee  Decimal? @db.Decimal(10,2)
  paidAt       DateTime?

  stripeTransferId  String?
  overeenkomstUrl   String?

  // Stripe Identity — biometrische check 10 min voor shift
  identitySessionId  String?
  identitySessionUrl String?
  identitySentAt     DateTime?
  identityVerifiedAt DateTime?

  appliedAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([shiftId, userId])
  @@map("shift_applications")
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
  COMPLETED
  APPROVED
}

// ─────────────────────────────────────────────
// VACANCY (fulltime)
// ─────────────────────────────────────────────
model Vacancy {
  id         String   @id @default(cuid())
  employerId String
  employer   Employer @relation(fields: [employerId], references: [id])

  title       String
  description String  @db.Text
  sector      Sector
  function    ZorgFunction
  city        String
  address     String?

  contractType  ContractType @default(LOONDIENST)
  hoursPerWeek  Int?
  salaryMin     Decimal? @db.Decimal(10,2)
  salaryMax     Decimal? @db.Decimal(10,2)

  requiresBig   Boolean @default(false)
  requiresSkj   Boolean @default(false)
  minExperience Int     @default(0)

  status        VacancyStatus @default(OPEN)

  placementFee    Decimal? @db.Decimal(10,2)
  placementFeePct Decimal? @db.Decimal(5,2)

  publishedAt DateTime  @default(now())
  expiresAt   DateTime?
  filledAt    DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([sector])
  @@index([status])
  @@map("vacancies")
}

enum VacancyStatus {
  DRAFT
  OPEN
  FILLED
  EXPIRED
  CANCELLED
}

// ─────────────────────────────────────────────
// REVIEWS
// ─────────────────────────────────────────────
model Review {
  id         String @id @default(cuid())
  reviewerId String
  reviewer   User   @relation("ReviewerUser", fields: [reviewerId], references: [id])
  reviewedId String
  reviewed   User   @relation("ReviewedUser", fields: [reviewedId], references: [id])

  rating     Int
  comment    String? @db.Text

  createdAt  DateTime @default(now())

  @@unique([reviewerId, reviewedId])
  @@map("reviews")
}

// ─────────────────────────────────────────────
// NEXTAUTH
// ─────────────────────────────────────────────
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Setting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt

  @@map("settings")
}

// ─────────────────────────────────────────────
// CHAT
// ─────────────────────────────────────────────
model ChatConversation {
  id           String        @id @default(cuid())
  visitorName  String?
  visitorEmail String?
  status       String        @default("open")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  messages     ChatMessage[]

  @@index([status])
  @@map("chat_conversations")
}

model ChatMessage {
  id             String           @id @default(cuid())
  conversationId String
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         String           // "visitor" | "admin"
  content        String           @db.Text
  createdAt      DateTime         @default(now())

  @@index([conversationId])
  @@map("chat_messages")
}

// ─────────────────────────────────────────────
// API KEYS (voor employer REST API)
// ─────────────────────────────────────────────
model ApiKey {
  id         String   @id @default(cuid())
  employerId String
  employer   Employer @relation(fields: [employerId], references: [id], onDelete: Cascade)

  name       String
  keyHash    String   @unique  // SHA-256 hash van de echte sleutel
  keyPrefix  String            // eerste 8 chars voor display ("sk_live_ab12...")
  lastUsedAt DateTime?
  isActive   Boolean  @default(true)

  createdAt  DateTime @default(now())

  @@index([keyHash])
  @@map("api_keys")
}

// ─────────────────────────────────────────────
// WEBHOOKS
// ─────────────────────────────────────────────
model WebhookEndpoint {
  id         String   @id @default(cuid())
  employerId String
  employer   Employer @relation(fields: [employerId], references: [id], onDelete: Cascade)

  url        String
  secret     String            // HMAC signing secret
  events     String[]          // ["shift.applied", "shift.filled", ...]
  isActive   Boolean  @default(true)
  description String?

  createdAt  DateTime @default(now())
  deliveries WebhookDelivery[]

  @@map("webhook_endpoints")
}

model WebhookDelivery {
  id         String          @id @default(cuid())
  endpointId String
  endpoint   WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  event      String
  payload    Json
  statusCode Int?
  success    Boolean @default(false)
  error      String?
  sentAt     DateTime @default(now())

  @@index([endpointId])
  @@map("webhook_deliveries")
}

// ─────────────────────────────────────────────
// LOCATIES (multi-locatie voor instellingen)
// ─────────────────────────────────────────────
model Location {
  id         String   @id @default(cuid())
  employerId String
  employer   Employer @relation(fields: [employerId], references: [id], onDelete: Cascade)

  name       String
  address    String
  city       String
  postalCode String
  isActive   Boolean  @default(true)

  createdAt  DateTime @default(now())
  shifts     Shift[]

  @@map("locations")
}

// ─────────────────────────────────────────────
// ZORGDECLARATIES
// ─────────────────────────────────────────────
model Declaratie {
  id         String   @id @default(cuid())
  nummer     String   @unique  // bijv. "DEC-2026-0001"

  // Van ZZP'er
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Aan opdrachtgever
  employerId String
  employer   Employer @relation(fields: [employerId], references: [id], onDelete: Cascade)

  periodeStart DateTime
  periodeEinde  DateTime

  regels     DeclaratieRegel[]

  totaalBedrag  Decimal  @db.Decimal(10,2)

  status        DeclaratieStatus @default(CONCEPT)
  notitie       String?   @db.Text   // notitie van ZZP'er
  afwijzingReden String?  @db.Text   // bij AFGEWEZEN

  ingediendAt    DateTime?
  goedgekeurdAt  DateTime?
  betaaldAt      DateTime?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId])
  @@index([employerId])
  @@map("declaraties")
}

model DeclaratieRegel {
  id            String     @id @default(cuid())
  declaratieId  String
  declaratie    Declaratie @relation(fields: [declaratieId], references: [id], onDelete: Cascade)

  omschrijving  String
  datum         DateTime
  uren          Decimal    @db.Decimal(5,2)
  tarief        Decimal    @db.Decimal(8,2)
  bedrag        Decimal    @db.Decimal(10,2)  // uren × tarief

  @@map("declaratie_regels")
}

enum DeclaratieStatus {
  CONCEPT
  INGEDIEND
  GOEDGEKEURD
  AFGEWEZEN
  BETAALD
}

// ─────────────────────────────────────────────
// BLOCKED WORKERS
// ─────────────────────────────────────────────
model BlockedWorker {
  id         String   @id @default(cuid())
  employerId String
  employer   Employer @relation(fields: [employerId], references: [id], onDelete: Cascade)
  workerId   String
  workerName String   // snapshot van naam op moment van blokkeren
  reason     String?
  createdAt  DateTime @default(now())

  @@unique([employerId, workerId])
  @@index([employerId])
  @@map("blocked_workers")
}

// ─────────────────────────────────────────────
// PUSH SUBSCRIPTIONS (web push notificaties)
// ─────────────────────────────────────────────
model PushSubscription {
  id       String @id @default(cuid())
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  endpoint String @unique
  p256dh   String
  auth     String

  createdAt DateTime @default(now())

  @@map("push_subscriptions")
}

// ─────────────────────────────────────────────
// SHIFT TEMPLATES (werkgever kan templates opslaan)
// ─────────────────────────────────────────────
model ShiftTemplate {
  id         String   @id @default(cuid())
  employerId String
  employer   Employer @relation(fields: [employerId], references: [id], onDelete: Cascade)

  name        String          // bijv. "Nacht verpleegkundige"
  title       String
  description String?  @db.Text
  sector      Sector
  function    ZorgFunction
  address     String
  city        String
  postalCode  String
  breakMinutes Int     @default(30)
  hourlyRate  Decimal  @db.Decimal(8,2)
  requiresBig  Boolean @default(false)
  requiresSkj  Boolean @default(false)
  requiresKvk  Boolean @default(true)

  createdAt  DateTime @default(now())

  @@index([employerId])
  @@map("shift_templates")
}

// ─────────────────────────────────────────────
// NOTIFICATIONS (in-app notificatiebell)
// ─────────────────────────────────────────────
model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  type      String   // "NEW_APPLICATION" | "SHIFT_ACCEPTED" | "CHECKOUT_PENDING" | "SHIFT_REMINDER" | etc
  title     String
  body      String
  href      String?  // link bij klik

  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
  @@map("notifications")
}

// ─────────────────────────────────────────────
// DIRECT MESSAGES (berichten tussen instelling en professional)
// ─────────────────────────────────────────────
model DirectConversation {
  id         String   @id @default(cuid())
  workerId   String   // userId of the worker
  employerId String   // userId of the employer contact

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  messages   DirectMessage[]

  @@unique([workerId, employerId])
  @@index([workerId])
  @@index([employerId])
  @@map("direct_conversations")
}

model DirectMessage {
  id             String              @id @default(cuid())
  conversationId String
  conversation   DirectConversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  senderId       String
  senderRole     String              // "WORKER" | "EMPLOYER"
  content        String              @db.Text
  read           Boolean             @default(false)
  createdAt      DateTime            @default(now())

  @@index([conversationId])
  @@map("direct_messages")
}

// ─────────────────────────────────────────────
// REFERRAL
// ─────────────────────────────────────────────
model ReferralReward {
  id          String   @id @default(cuid())
  referrerId  String
  referrer    User     @relation(fields: [referrerId], references: [id], onDelete: Cascade)
  referredId  String   @unique
  bonusAmount Decimal  @default(25.00) @db.Decimal(8,2)
  paidOut     Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([referrerId])
  @@map("referral_rewards")
}
